# Loop Orchestra - Environment Secrets (Faz 4)
# UYARI: Bu dosya asla Git'e commit edilmemelidir (.gitignore içinde olmalı).
# Ajanlar (Claude/Codex) bu dosyaya veya ortam değişkenlerine ASLA doğrudan erişemez.
# Sadece Dispatcher bu değerleri okur ve güvenli bir şekilde subprocess'lere aktarır.

# 1. API Anahtarları (Sadece Dispatcher kullanır)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxx
CODEX_API_KEY=sk-xxxxxxxxxxxxxxxxx

# 2. Telegram Kill-Switch Bildirimleri (Faz 4/5n)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=-1001234567890

# 3. Quota Guard Ayarları (Dinamik Hız Ayarı için eşikler)
QUOTA_CRITICAL_PERCENTAGE=20
CLAUDE_RESET_WINDOW_HOURS=5
